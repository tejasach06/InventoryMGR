    "/_tree",
    "/_full",
    "/!KGFwcCk/imports/new/__PAGE__",
    "/!KGFwcCk/imports/new",
    "/!KGFwcCk/imports",
    "/!KGFwcCk",
    "/_index",
    "/_head"
  ]
}
{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.17.3/.schema/devbox.schema.json",
  "packages": [
    "python@3.12",
    "nodejs@22",
    "uv",
    "just"
  ],
  "env": {
    "DATABASE_URL": "postgresql+psycopg://inventorymgr@127.0.0.1:54329/inventorymgr",
    "TEST_DATABASE_URL": "postgresql+psycopg://inventorymgr@127.0.0.1:54329/inventorymgr_test"
  },
  "shell": {
    "init_hook": [
      "export PATH=\"$HOME/.bun/bin:$PATH\""
    ],
    "scripts": {
      "setup": [
        "(cd backend && uv sync --extra dev)",
        "[ -x \"$HOME/.bun/bin/bun\" ] || (curl -fsSL https://bun.sh/install | BUN_INSTALL=\"$HOME/.bun\" bash)",
        "(cd frontend && bun install)",
        "(cd backend && uv run alembic upgrade head)"
      ]
    }
  }
}

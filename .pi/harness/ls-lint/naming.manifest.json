{
	"schema_version": "1.0.0",
	"project": "ultimate-pi",
	"global_rules": {
		".*": "regex:^[a-z]+(?:-[a-z]+)*$",
		".md": "regex:^[a-z]+(?:-[a-z]+)*$",
		".ts": "regex:^[a-z]+(?:-[a-z]+)*$",
		".tsx": "regex:^[a-z]+(?:-[a-z]+)*$",
		".mjs": "regex:^[a-z]+(?:-[a-z]+)*$",
		".js": "regex:^[a-z]+(?:-[a-z]+)*$",
		".json": "regex:^[a-z]+(?:-[a-z]+)*$",
		".yaml": "regex:^[a-z]+(?:-[a-z]+)*$",
		".yml": "regex:^[a-z]+(?:-[a-z]+)*$",
		".toml": "regex:^[a-z]+(?:-[a-z]+)*$",
		".py": "regex:^[a-z]+(?:-[a-z]+)*$",
		".sh": "regex:^[a-z]+(?:-[a-z]+)*$",
		".css": "regex:^[a-z]+(?:-[a-z]+)*$",
		".html": "regex:^[a-z]+(?:-[a-z]+)*$"
	},
	"scoped_rules": [
		{
			"path": ".pi/harness/docs/adrs",
			"rules": {
				".md": "regex:^\\d{4}-[a-z-]+$|^template$"
			}
		},
		{
			"path": ".agents/skills",
			"rules": {
				".dir": "kebab-case",
				".md": "regex:^SKILL\\.md$"
			}
		},
		{
			"path": "scripts",
			"rules": {
				".dir": "kebab-case"
			}
		},
		{
			"path": "docs",
			"rules": {
				".dir": "kebab-case"
			}
		},
		{
			"path": ".pi/scripts",
			"rules": {
				".dir": "snake_case"
			}
		},
		{
			"path": ".pi/agents",
			"rules": {
				".dir": "kebab-case"
			}
		}
	],
	"ignores": [
		".git",
		"node_modules",
		"graphify-out",
		"graphify-books-out",
		"vendor",
		"dist",
		"build",
		"coverage",
		".web",
		".cursor",
		".github",
		".agents",
		".pi/npm",
		".pi/harness/runs",
		".pi/harness/debates",
		".pi/harness/.lens",
		".pi/wiki-search",
		".cocoindex_code",
		".sentrux",
		".ls-lint",
		".searxng",
		".vault-meta",
		".raw",
		"raw",
		"data",
		"**/__pycache__/**",
		"submissions",
		"jobs",
		"pl",
		"**/*.png",
		"**/*.jpg",
		"**/*.jpeg",
		"**/*.gif",
		"**/*.webp",
		"**/*.ico",
		"**/*.svg",
		"package-lock.json",
		"pnpm-lock.yaml",
		"yarn.lock",
		"*.lock",
		"README.md",
		"**/README.md",
		"SKILL.md",
		"**/SKILL.md",
		"CHANGELOG.md",
		"LICENSE",
		"AGENTS.md",
		"CONTRIBUTING.md",
		"THIRD_PARTY_NOTICES.md",
		".env.example",
		"skills-lock.json",
		".fallow-baseline.json",
		".graphify_detect.json",
		".graphify_python",
		".graphify_root",
		".graphify_incremental.json",
		".pi/SYSTEM.md",
		".pi/PACKAGING.md",
		"**/.*",
		".pi/sounds",
		".pi/harness/evals",
		".pi/extensions/00-harness-project-control.ts",
		"DOCS_BY_AUDIENCE.md",
		"GLOSSARY.md",
		"REPO_MAP.md",
		"START_HERE.md",
		"WORKFLOW_CHEAT_SHEET.md"
	]
}

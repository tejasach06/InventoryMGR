{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "graphify": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "graphify-mcp-tools",
        "mcp",
        "--graph",
        "./graphify-out"
      ]
    }
  },
  "plugin": [
    ".opencode/plugins/graphify-mcp-tools.js"
  ],
  "compaction": {
    "auto": true,
    "tail_turns": 15
  }
}
